# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=inventory_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password   # ⚠️ CHANGE THIS

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string  # ⚠️ CHANGE THIS
APP_ENV=production
# Comma-separated list — no wildcards
CORS_ORIGINS=http://localhost:80,http://localhost:3000,http://localhost

# ── Frontend ──────────────────────────────────────────────────────────────────
# Leave empty to use nginx proxy (Docker); set for hosted deployment:
# REACT_APP_API_URL=https://your-backend.railway.app
REACT_APP_API_URL=
